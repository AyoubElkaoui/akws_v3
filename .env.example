# Contact formulier via Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# E-mailadres waar contactformulier naartoe stuurt
CONTACT_EMAIL=info@akwebsolutions.nl

# Afzender e-mailadres (moet verified domain zijn in Resend)
RESEND_FROM=noreply@akwebsolutions.nl

# reCAPTCHA v3 (https://www.google.com/recaptcha/admin)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6Lf...           # publiek, veilig in browser
RECAPTCHA_SECRET_KEY=6Lf...                     # geheim, alleen server-side

# Publieke site-URL (zonder trailing slash)
NEXT_PUBLIC_SITE_URL=https://akwebsolutions.nl
